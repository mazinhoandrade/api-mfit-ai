// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id
  workoutPlans    WorkoutPlan[]
  name            String
  email           String
  emailVerified   Boolean          @default(false)
  image           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  workoutSessions WorkoutSession[]
  sessions        Session[]
  accounts        Account[]
  bodyMetrics     BodyMetric[]
  dietLogs        DietLog[]
  aianalyses      AIAnalysis[]

  @@unique([email])
  @@map("user")
}

model BodyMetric {
  id                  String @id @default(uuid())
  userId              String
  age                 Int?
  weightInGrams       Int?
  heightInCentimeters Int?

  bodyFatPercentage Int?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DietLog {
  id        String   @id @default(uuid())
  userId    String
  calories  Int
  protein   Int
  carbs     Int
  fat       Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AIAnalysis {
  id        String   @id @default(uuid())
  userId    String
  content   Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkoutPlan {
  id          String       @id @default(uuid())
  name        String
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutDays WorkoutDay[]
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now()) @db.Timestamptz()
  updatedAt   DateTime     @updatedAt @db.Timestamptz()
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model WorkoutDay {
  id                         String            @id @default(uuid())
  name                       String
  workoutPlanId              String
  workoutPlan                WorkoutPlan       @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  isRest                     Boolean           @default(false)
  weekDay                    WeekDay
  exercises                  WorkoutExercise[]
  sessions                   WorkoutSession[]
  estimatedDurationInSeconds Int
  coverImageUrl              String?
  createdAt                  DateTime          @default(now()) @db.Timestamptz()
  updatedAt                  DateTime          @updatedAt @db.Timestamptz()
}

enum ExerciseMetricType {
  WEIGHT_REPS
  REPS_ONLY
  TIME
  DISTANCE_TIME
}

model WorkoutExercise {
  id                String             @id @default(uuid())
  name              String
  order             Int
  workoutDayId      String
  workoutDay        WorkoutDay         @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  metricType        ExerciseMetricType
  suggestedWeight   Int?
  sets              Int?
  reps              Int?
  restTimeInSeconds Int?
  notes             String?
  durationInSeconds Int?
  distanceInMeters  Int?
  createdAt         DateTime           @default(now()) @db.Timestamptz()
  updatedAt         DateTime           @updatedAt @db.Timestamptz()
  exerciseLogs      ExerciseLog[]
}

model ExerciseLog {
  id         String   @id @default(uuid())
  sessionId  String
  exerciseId String
  notes      String?
  createdAt  DateTime @default(now())

  session  WorkoutSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise WorkoutExercise @relation(fields: [exerciseId], references: [id])

  sets ExerciseSet[]

  @@unique([sessionId, exerciseId])
}

model ExerciseSet {
  id    String      @id @default(uuid())
  logId String
  log   ExerciseLog @relation(fields: [logId], references: [id], onDelete: Cascade)

  order             Int
  weight            Int?
  reps              Int?
  durationInSeconds Int?
  distanceInMeters  Int?
  completed         Boolean @default(false)

  createdAt DateTime @default(now())
}

model WorkoutSession {
  id           String        @id @default(uuid())
  workoutDayId String
  workoutDay   WorkoutDay    @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt    DateTime      @db.Timestamptz()
  completedAt  DateTime?     @db.Timestamptz()
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now()) @db.Timestamptz()
  updatedAt    DateTime      @updatedAt @db.Timestamptz()
  exerciseLogs ExerciseLog[]

  @@unique([userId, workoutDayId, isActive])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
